generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TRAINER
}

enum WorkshopStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  ARCHIVED
}

enum BlockType {
  BLOCK
  GROUP
  BREAKOUT
  NOTE
}

enum LiveStatus {
  IDLE
  RUNNING
  PAUSED
  ENDED
}

enum TemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  parentOrgId String?
  parentOrg   Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  children    Organization[] @relation("OrgHierarchy")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users     User[]
  workshops Workshop[]
  boards    Board[]

  @@index([parentOrgId])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  email     String?  @unique
  role      UserRole @default(TRAINER)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  workshops         Workshop[]        @relation("WorkshopCreator")
  assignedBlocks    Block[]           @relation("BlockAssignee")
  createdTemplates  Template[]        @relation("TemplateCreator")
  approvedTemplates Template[]        @relation("TemplateApprover")
  templateRatings   TemplateRating[]
  createdMethods    Method[]          @relation("MethodCreator")
  approvedMethods   Method[]          @relation("MethodApprover")
  comments          Comment[]
  liveControllers   LiveSession[]     @relation("LiveController")
  coachNotes        CoachNote[]       @relation("CoachNoteAuthor")
  sharedWorkshops   WorkshopShare[]
  blockCategories   BlockCategory[]
  workshopVersions  WorkshopVersion[]
  createdBoards     Board[]           @relation("BoardCreator")

  @@index([organizationId])
}

model BlockCategory {
  id          String   @id @default(cuid())
  name        String
  color       String   // oklch / hex string used in UI
  position    Int      @default(0)
  isSystem    Boolean  @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  blocks    Block[]

  @@index([createdById])
}

model Workshop {
  id          String         @id @default(cuid())
  title       String         @default("Untitled session")
  /// Short one-line goal of the session — "what should be achieved by the end".
  goals       String?
  description String?        @db.Text
  status      WorkshopStatus @default(DRAFT)
  clientName  String?
  tags        String[]       @default([])
  startDate   DateTime?
  timezone    String         @default("Europe/Zurich")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdById String
  createdBy   User   @relation("WorkshopCreator", fields: [createdById], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  days          Day[]
  shares        WorkshopShare[]
  comments      Comment[]
  materials     Material[]
  liveSessions  LiveSession[]
  versions      WorkshopVersion[]
  boards        WorkshopBoard[]

  @@index([createdById])
  @@index([organizationId])
  @@index([status])
}

model WorkshopVersion {
  id          String   @id @default(cuid())
  workshopId  String
  workshop    Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  /// JSON snapshot of the entire workshop incl. days, blocks, tasks, materials.
  snapshot    Json
  /// Optional label set by the user (e.g. "vor der Galliker-Probe").
  label       String?
  /// "manual" | "auto" | "before_restore"
  kind        String   @default("manual")
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([workshopId, createdAt])
  @@index([createdById])
}

model WorkshopShare {
  workshopId String
  userId     String
  canEdit    Boolean @default(true)

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workshopId, userId])
}

model Day {
  id         String   @id @default(cuid())
  workshopId String
  position   Int
  title      String?
  startTime  String   @default("09:00")
  date       DateTime?

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  blocks   Block[]

  @@unique([workshopId, position])
  @@index([workshopId])
}

model Block {
  id          String    @id @default(cuid())
  dayId       String
  position    Int
  /// For BREAKOUT-children: which parallel column (track) the block lives in.
  /// Ignored for top-level and GROUP-children.
  column      Int       @default(0)
  type        BlockType @default(BLOCK)
  title       String    @default("")
  description String?   @db.Text
  /// Trainer-only notes — visible in editor, hidden in display view.
  notes       String?   @db.Text
  duration    Int       @default(15)
  locked      Boolean   @default(false)
  startTime   String?

  parentBlockId String?
  parentBlock   Block?  @relation("BlockChildren", fields: [parentBlockId], references: [id], onDelete: Cascade)
  childBlocks   Block[] @relation("BlockChildren")

  categoryId String?
  category   BlockCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  methodId String?
  method   Method? @relation(fields: [methodId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("BlockAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  day       Day        @relation(fields: [dayId], references: [id], onDelete: Cascade)
  tasks     Task[]
  comments  Comment[]
  materials Material[]

  @@index([dayId])
  @@index([parentBlockId])
  @@index([methodId])
  @@index([categoryId])
}

model Task {
  id        String   @id @default(cuid())
  blockId   String
  text      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
}

model Material {
  id         String  @id @default(cuid())
  workshopId String
  blockId    String?
  name       String
  quantity   Int?
  notes      String?
  /// Optional external link (Miro, Figma, Google Docs, …). When set, the
  /// material is treated as a tool/link asset rather than a physical item;
  /// quantity is typically null in that case. WORKSHOP-LEVEL links
  /// (blockId=null + url set) were migrated to the Board model — keep this
  /// field around for block-level link assets only.
  url        String?

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  block    Block?   @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([workshopId])
}

/// External board/asset (Miro, Figma, Google Slides, Notion, …). Used as a
/// shared library so the same Miro can be attached to multiple workshops.
/// `isMaster=true` marks templates that any UNION trainer can pick into a
/// new workshop with one click.
model Board {
  id             String   @id @default(cuid())
  title          String
  url            String
  /// Auto-detected from URL on the client (miro / figma / notion / google-doc / …).
  /// Stored only as a hint — the canonical kind is recomputed when displayed.
  kind           String?
  notes          String?  @db.Text
  tags           String[] @default([])
  /// Master boards are reusable templates. Listed prominently in the picker
  /// and visible across orgs in the UNION.
  isMaster       Boolean  @default(false)
  createdById    String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy    User            @relation("BoardCreator", fields: [createdById], references: [id], onDelete: Cascade)
  organization Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workshops    WorkshopBoard[]

  @@index([createdById])
  @@index([organizationId])
  @@index([isMaster])
}

/// Many-to-many between Workshop and Board. Per-workshop overrides for the
/// notes are allowed (e.g. the same master Miro might have different
/// instructions per workshop).
model WorkshopBoard {
  workshopId String
  boardId    String
  notes      String?
  addedAt    DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@id([workshopId, boardId])
  @@index([workshopId])
  @@index([boardId])
}

model Method {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  instructions    String?        @db.Text
  defaultDuration Int            @default(15)
  category        String?
  tags            String[]       @default([])
  isPublic        Boolean        @default(false)
  /// Snapshot of the full block hierarchy (BLOCK / GROUP / BREAKOUT / NOTE)
  /// in the same shape as WorkshopVersion.snapshot. Null for legacy single-block
  /// system methods that pre-date the block-logic rollout.
  blocksJson      Json?
  /// Submission workflow. Default APPROVED so seeded system methods stay live;
  /// new user submissions explicitly set PENDING via createMethodAction.
  status          TemplateStatus @default(APPROVED)
  rejectedReason  String?
  approvedById    String?
  approvedAt      DateTime?
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy  User    @relation("MethodCreator", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy User?   @relation("MethodApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  blocks     Block[]

  @@index([createdById])
  @@index([category])
  @@index([status])
}

model Template {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  /// Required theme (e.g. "Leadership", "Strategie", "Onboarding").
  theme           String
  tags            String[]       @default([])
  duration        Int            @default(0)
  /// Full workshop snapshot (same shape as WorkshopVersion).
  blocksJson      Json
  status          TemplateStatus @default(PENDING)
  rejectedReason  String?
  /// Denormalized rating cache for cheap sorts.
  avgRating       Float?
  ratingCount     Int            @default(0)
  /// How many times this template was used to spawn a workshop.
  useCount        Int            @default(0)
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy   User             @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy  User?            @relation("TemplateApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  ratings     TemplateRating[]

  @@index([createdById])
  @@index([status])
  @@index([theme])
}

model TemplateRating {
  id         String   @id @default(cuid())
  templateId String
  userId     String
  score      Int      // 1..5
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([templateId, userId])
  @@index([templateId])
  @@index([userId])
}

model LiveSession {
  id              String     @id @default(cuid())
  workshopId      String
  controllerId    String
  status          LiveStatus @default(IDLE)
  currentBlockId  String?
  startedAt       DateTime?
  pausedAt        DateTime?
  endedAt         DateTime?
  blockTimings    Json       @default("[]")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workshop   Workshop    @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  controller User        @relation("LiveController", fields: [controllerId], references: [id], onDelete: Cascade)
  coachNotes CoachNote[]

  @@index([workshopId])
  @@index([status])
}

/// Live whisper notes from a co-trainer to the controller — silent, ephemeral.
model CoachNote {
  id            String      @id @default(cuid())
  liveSessionId String
  authorId      String
  content       String      @db.Text
  /// Which block was current when the note was sent (purely for context).
  blockId       String?
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())

  liveSession LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  author      User        @relation("CoachNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  workshopId String
  blockId    String?
  authorId   String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  block    Block?   @relation(fields: [blockId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([blockId])
}
